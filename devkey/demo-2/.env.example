# GCP Configuration
GOOGLE_CLOUD_PROJECT=<YOUR_PROJECT_ID>
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
BUCKET_URI=gs://<YOUR_STAGING_BUCKET>

# Agent Resource Names (populated after deploying each agent to Agent Engine)
# Format: projects/PROJECT_NUMBER/locations/LOCATION/reasoningEngines/AGENT_ID
# For local development, use: local:PORT (e.g., local:8089)
SIMULATOR_AGENT_RESOURCE_NAME=

# Model Configuration (defaults shown, uncomment to override)
# PLANNER_MODEL=gemini-2.5-flash
# SIMULATOR_MODEL=gemini-2.5-flash
