# Cloud Build ignore file
# Note: uv.lock is intentionally NOT ignored here (unlike .gitignore)
# because we need it for reproducible Docker builds

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environment
.venv/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/

# Environment files (secrets)
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.sublime-*
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Git
.git/
.gitignore

# Terraform state (sensitive)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/tfplan

# Claude Code local files
CLAUDE.local.md

# GitHub templates
.github/
